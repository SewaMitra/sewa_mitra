rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: check if the requester is an admin ─────────────────
    // Uses request.auth.token if you set custom claims, otherwise
    // falls back to a Firestore document read.
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users ───────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['uid', 'fullName', 'email', 'createdAt']);
      // Users can update their own doc; admins can update any
      allow update: if request.auth != null
                    && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Provider Applications ───────────────────────────────────────
    match /provider_applications/{appId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid || isAdmin());
      // FIX: also allow the owner to read their own application after creation
      allow update, delete: if isAdmin();
    }

    // ── Providers ───────────────────────────────────────────────────
    match /providers/{providerId} {
      allow read: if request.auth != null;
      // FIX: allow write if admin OR if it's the provider updating their own doc
      allow write: if isAdmin()
                   || (request.auth != null && request.auth.uid == providerId);
    }

    // ── Earnings ────────────────────────────────────────────────────
    match /earnings/{earningId} {
      allow read: if request.auth != null
                  && (resource.data.providerId == request.auth.uid || isAdmin());
      allow create, update: if request.auth != null;
      allow delete: if isAdmin();
    }

    // ── Wallets ─────────────────────────────────────────────────────
    match /wallets/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Transactions ────────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if request.auth != null
                  && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ── Bookings ────────────────────────────────────────────────────
    match /bookings/{bookingId} {
      allow read: if request.auth != null
                  && (resource.data.customerId == request.auth.uid
                      || resource.data.providerId == request.auth.uid
                      || isAdmin());
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && (resource.data.customerId == request.auth.uid
                        || resource.data.providerId == request.auth.uid
                        || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
